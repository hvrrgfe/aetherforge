<UserControl x:Class="AetherForgeStudio.Controls.TransactionBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border BorderBrush="{ThemeResource CardBackgroundFillColorDefault}" BorderThickness="1" CornerRadius="6" Padding="8">
        <StackPanel Orientation="Horizontal" Spacing="16">
            <TextBlock x:Name="TxStatus" Text="No active transaction" VerticalAlignment="Center"/>
            <TextBlock x:Name="WorldRevText" Text="Rev: 0" VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>