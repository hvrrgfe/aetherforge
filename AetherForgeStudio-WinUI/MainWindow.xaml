<Window x:Class="AetherForgeStudio.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>
        <NavigationView Grid.Row="0" x:Name="NavView" PaneDisplayMode="Top"
            ItemInvoked="NavView_ItemInvoked" IsSettingsVisible="False">
            <NavigationView.MenuItems>
                <NavigationViewItem Tag="Dashboard" Content="仪表盘">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="Home"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="AgentWorkspace" Content="Agent 工作台">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="People"/></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="Verification" Content="验证中心">
                    <NavigationViewItem.Icon><SymbolIcon Symbol="Accept"/></NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
        </NavigationView>
        <Frame Grid.Row="1" x:Name="ContentFrame"/>
        <TextBlock Grid.Row="2" x:Name="StatusBar" Text="就绪" VerticalAlignment="Center" Margin="8,0"/>
    </Grid>
</Window>
