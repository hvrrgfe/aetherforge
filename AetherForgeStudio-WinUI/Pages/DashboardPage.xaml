<Page x:Class="AetherForgeStudio.Pages.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer><StackPanel Padding="16" Spacing="12">
        <TextBlock x:Uid="DashboardTitle" Style="{StaticResource TitleTextBlockStyle}"/>
        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" BorderBrush="{ThemeResource CardBackgroundFillColorDefault}" BorderThickness="1" CornerRadius="8" Padding="12">
                <TextBlock x:Uid="EntityLabel" Text="Entities" FontWeight="Bold"/>
                <TextBlock x:Uid="EntityCount" x:Name="EntityCount" FontSize="32"/>
            </StackPanel>
            <StackPanel Grid.Column="1" BorderBrush="{ThemeResource CardBackgroundFillColorDefault}" BorderThickness="1" CornerRadius="8" Padding="12">
                <TextBlock x:Uid="RuleLabel" Text="Rules" FontWeight="Bold"/>
                <TextBlock x:Uid="RuleCount" x:Name="RuleCount" FontSize="32"/>
            </StackPanel>
            <StackPanel Grid.Column="2" BorderBrush="{ThemeResource CardBackgroundFillColorDefault}" BorderThickness="1" CornerRadius="8" Padding="12">
                <TextBlock x:Uid="QuestLabel" Text="Quests" FontWeight="Bold"/>
                <TextBlock x:Uid="QuestCount" x:Name="QuestCount" FontSize="32"/>
            </StackPanel>
            <StackPanel Grid.Column="3" BorderBrush="{ThemeResource CardBackgroundFillColorDefault}" BorderThickness="1" CornerRadius="8" Padding="12">
                <TextBlock x:Uid="RevisionLabel" Text="Revision" FontWeight="Bold"/>
                <TextBlock x:Uid="RevisionCount" x:Name="RevisionCount" FontSize="32"/>
            </StackPanel>
        </Grid>
        <Button x:Uid="RefreshBtn" x:Name="RefreshBtn" Content="Refresh" Click="RefreshBtn_Click" HorizontalAlignment="Left"/>
    </StackPanel></ScrollViewer>
</Page>