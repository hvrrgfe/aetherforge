<Page x:Class="AetherForgeStudio.Pages.WorldPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock x:Uid="WorldTitle" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,12"/>
        <TreeView x:Name="WorldTree" Grid.Row="1"/>
    </Grid>
</Page>