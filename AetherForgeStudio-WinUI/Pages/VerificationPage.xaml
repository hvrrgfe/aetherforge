<Page x:Class="AetherForgeStudio.Pages.VerificationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:AetherForgeStudio.Controls">
    <Grid Padding="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
            <TextBox x:Name="TaskIdInput" PlaceholderText="输入任务 ID" Width="300"/>
            <Button Content="加载证据" Click="LoadEvidenceBtn_Click"/>
            <Button x:Name="CommitBtn" Content="提交" Click="CommitBtn_Click"/>
            <Button x:Name="RollbackBtn" Content="回滚" Click="RollbackBtn_Click"/>
        </StackPanel>
        <controls:EvidencePanel Grid.Row="1" x:Name="EvidencePanel" Margin="0,12"/>
        <controls:TransactionBar Grid.Row="2" x:Name="TxBar"/>
    </Grid>
</Page>
