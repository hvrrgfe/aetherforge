package com.aetherforge.ui;

import com.aetherforge.model.Entity;
import com.aetherforge.util.Colors;
import javax.swing.*;
import java.awt.*;
import java.awt.event.*;
import java.util.List;

/**
 * 2D 视口面板 — 支持平移、缩放、选中和拖拽实体
 */
public class ViewportPanel extends JPanel {

    private final MainWindow window;
    private Point dragStart;
    private boolean isDragging;
    private int dragOffsetX, dragOffsetY;
    private Entity dragEntity;

    public ViewportPanel(MainWindow window) {
        this.window = window;
        setBackground(Colors.BACKGROUND_DEEPEST);
        setFocusable(true);
        setCursor(Cursor.getPredefinedCursor(Cursor.CROSSHAIR_CURSOR));

        ViewportMouseHandler mouseHandler = new ViewportMouseHandler();
        addMouseListener(mouseHandler);
        addMouseMotionListener(mouseHandler);
        addMouseWheelListener(mouseHandler);

        addKeyListener(new KeyAdapter() {
            @Override
            public void keyPressed(KeyEvent e) {
                if (e.getKeyCode() == KeyEvent.VK_DELETE && window.getSelectedEntity() != null) {
                    window.deleteSelectedEntity();
                }
            }
        });
    }

    @Override
    protected void paintComponent(Graphics g) {
        super.paintComponent(g);
        Graphics2D g2 = (Graphics2D) g.create();
        g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
        g2.setRenderingHint(RenderingHints.KEY_TEXT_ANTIALIASING, RenderingHints.VALUE_TEXT_ANTIALIAS_LCD_HRGB);
        g2.setRenderingHint(RenderingHints.KEY_RENDERING, RenderingHints.VALUE_RENDER_QUALITY);

        int width = getWidth(), height = getHeight();
        double zoom = window.getCameraZoom();
        double camX = window.getCameraX();
        double camY = window.getCameraY();

        // 绘制网格
        drawGrid(g2, width, height, zoom, camX, camY);

        // 绘制原点标记
        drawOrigin(g2, width, height, zoom, camX, camY);

        // 绘制所有实体
        List<Entity> entities = window.getEntities();
        for (Entity entity : entities) {
            paintEntity(g2, entity, zoom, camX, camY, width, height);
        }

        // 绘制选中高亮
        Entity selected = window.getSelectedEntity();
        if (selected != null) {
            drawSelectionHighlight(g2, selected, zoom, camX, camY, width, height);
        drawViewportHUD(g2, width, height, zoom, camX, camY);
        }

        // 缩放指示
        g2.setFont(new Font("Segoe UI", Font.PLAIN, 11));
        g2.setColor(Colors.TEXT_MUTED);
        g2.drawString(String.format("%.0f%%", zoom * 100), width - 55, height - 14);

        g2.dispose();
    }

    private void drawGrid(Graphics2D g2, int width, int height, double zoom, double camX, double camY) {
        g2.setColor(Colors.GRID_LINE);
        float gridSize = 32;
        float scaledGrid = (float) (gridSize * zoom);
        if (scaledGrid < 4) scaledGrid = 4;

        double offsetX = (width / 2.0 + camX * zoom) % scaledGrid;
        double offsetY = (height / 2.0 + camY * zoom) % scaledGrid;

        for (double x = offsetX; x < width; x += scaledGrid) {
            g2.drawLine((int) x, 0, (int) x, height);
        }
        for (double y = offsetY; y < height; y += scaledGrid) {
            g2.drawLine(0, (int) y, width, (int) y);
        }
    }

    private void drawOrigin(Graphics2D g2, int width, int height, double zoom, double camX, double camY) {
        int originX = (int) (width / 2.0 + camX * zoom);
        int originY = (int) (height / 2.0 + camY * zoom);

        g2.setColor(Colors.ORIGIN_LINE);
        g2.drawLine(originX - 20, originY, originX + 20, originY);
        g2.drawLine(originX, originY - 20, originX, originY + 20);

        g2.setColor(Colors.BLUE);
        g2.fillOval(originX - 2, originY - 2, 4, 4);
    }

    private void paintEntity(Graphics2D g2, Entity entity, double zoom, double camX, double camY, int panelW, int panelH) {
        float screenX = (float) (panelW / 2.0 + (entity.getX() + camX) * zoom);
        float screenY = (float) (panelH / 2.0 + (entity.getY() + camY) * zoom);
        float drawWidth = Math.max(4, (float) (entity.getWidth() * zoom));
        float drawHeight = Math.max(4, (float) (entity.getHeight() * zoom));

        g2.setColor(entity.getColor());
        g2.setComposite(AlphaComposite.getInstance(AlphaComposite.SRC_OVER,
            entity.isPlayer() ? 1.0f : 0.85f));

        if (entity.isCircle()) {
            g2.fillOval((int) (screenX - drawWidth / 2), (int) (screenY - drawHeight / 2),
                       (int) drawWidth, (int) drawHeight);
        } else {
            g2.fillRect((int) (screenX - drawWidth / 2), (int) (screenY - drawHeight / 2),
                       (int) drawWidth, (int) drawHeight);
        }

        // 名称标签
        if (zoom > 0.3) {
            g2.setComposite(AlphaComposite.getInstance(AlphaComposite.SRC_OVER, 1.0f));
            g2.setColor(Colors.TEXT_SECONDARY);
            float fontSize = Math.max(9, (int) (11 * Math.min(1, zoom)));
            g2.setFont(new Font("Segoe UI", Font.PLAIN, (int) fontSize));
            FontMetrics fm = g2.getFontMetrics();
            int textWidth = fm.stringWidth(entity.getName());
            g2.drawString(entity.getName(),
                (int) (screenX - textWidth / 2.0),
                (int) (screenY + drawHeight / 2.0 + fm.getAscent() + 3));
        }
    }

    private void drawSelectionHighlight(Graphics2D g2, Entity selected, double zoom, double camX, double camY, int panelW, int panelH) {
        float screenX = (float) (panelW / 2.0 + (selected.getX() + camX) * zoom);
        float screenY = (float) (panelH / 2.0 + (selected.getY() + camY) * zoom);
        float drawWidth = (float) (selected.getWidth() * zoom);
        float drawHeight = (float) (selected.getHeight() * zoom);

        // 外发光框
        g2.setColor(new Color(0x40, 0x80, 0xf0, 60));
        g2.setStroke(new BasicStroke(1.5f));
        g2.drawRect((int) (screenX - drawWidth / 2 - 4), (int) (screenY - drawHeight / 2 - 4),
                   (int) (drawWidth + 8), (int) (drawHeight + 8));
    }

    // ==================== 鼠标事件处理 ====================

    private class ViewportMouseHandler extends MouseAdapter {
        @Override
        public void mousePressed(MouseEvent e) {
            requestFocusInWindow();
            double worldX = screenToWorldX(e.getX());
            double worldY = screenToWorldY(e.getY());

            // 检测实体点击
            Entity hit = null;
            for (Entity entity : window.getEntities()) {
                if (entity.containsPoint(worldX, worldY)) {
                    hit = entity;
                    break;
                }
            }

            if (hit != null) {
                window.setSelectedEntity(hit);
                dragEntity = hit;
                isDragging = true;
                dragOffsetX = e.getX();
                dragOffsetY = e.getY();
            } else {
                window.setSelectedEntity(null);
                isDragging = true;
                dragStart = e.getPoint();
            }
            window.refreshInspector();
            window.repaintSceneTree();
            repaint();
        }

        @Override
        public void mouseDragged(MouseEvent e) {
            if (!isDragging) return;

            if (dragEntity != null) {
                double deltaX = (e.getX() - dragOffsetX) / window.getCameraZoom();
                double deltaY = (e.getY() - dragOffsetY) / window.getCameraZoom();
                dragEntity.setPosition(dragEntity.getX() + deltaX, dragEntity.getY() + deltaY);
                dragOffsetX = e.getX();
                dragOffsetY = e.getY();
                window.refreshInspector();
            } else if (dragStart != null) {
                window.moveCamera(
                    -(e.getX() - dragStart.x) / window.getCameraZoom(),
                    -(e.getY() - dragStart.y) / window.getCameraZoom()
                );
                dragStart = e.getPoint();
            }
            window.updateStatusBar();
            repaint();
        }

        @Override
        public void mouseReleased(MouseEvent e) {
            isDragging = false;
            dragEntity = null;
            dragStart = null;
        }

        @Override
        public void mouseWheelMoved(MouseWheelEvent e) {
            double factor = e.getWheelRotation() > 0 ? 1.0 / 1.12 : 1.12;
            window.zoomCamera(factor);
            repaint();
        }
    }

    // ==================== 坐标转换 ====================

    public double screenToWorldX(int screenX) {
        return (screenX - getWidth() / 2.0) / window.getCameraZoom() - window.getCameraX();
    }

    public double screenToWorldY(int screenY) {
        return (screenY - getHeight() / 2.0) / window.getCameraZoom() - window.getCameraY();
    }

    private void drawViewportHUD(Graphics2D g2, int w, int h, double zoom, double camX, double camY) {
        g2.setFont(new Font(java.awt.Font.SANS_SERIF, java.awt.Font.PLAIN, 11));
        g2.setColor(Colors.TEXT_MUTED);
        g2.drawString(String.format("%.0f%%", zoom*100), w-55, h-14);
        g2.setColor(Colors.BORDER_LINE);
        g2.fillRect(w-55, h-28, 40, 3);
        g2.setColor(Colors.BLUE);
        int fill = (int)(40 * Math.min(1.0, Math.max(0.05, zoom)/20.0));
        g2.fillRect(w-55, h-28, fill, 3);
    }

}
